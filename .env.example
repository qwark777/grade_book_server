# MySQL Database Configuration
# Для локальной разработки используй: MYSQL_HOST=localhost
# Для Docker используй: MYSQL_HOST=db (или не указывай, будет использовано по умолчанию)
MYSQL_HOST=localhost
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=root
# ВАЖНО: В Docker для подключения как root используй MYSQL_ROOT_PASSWORD
# Если используешь отдельного пользователя, установи MYSQL_PASSWORD
MYSQL_PASSWORD=12345678
MYSQL_DB=grade_book
MYSQL_PORT=3306

# Application Configuration
APP_PORT=8001

# Security Keys (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=304f1388f317fe2e917a1df468144def7f60586ba96dc80b07d26c68cae00fab
ENCRYPTION_KEY=ICkoftk-wbOx89vzo2nuGkPatHZCQ1IKBVpFdRJ1F4k=

# Owner Account (for first-time setup - автоматически создается при первом запуске)
# ВАЖНО: Измени пароль в продакшене!
OWNER_USERNAME=owner
OWNER_PASSWORD=test_password_123
OWNER_FULL_NAME=Test Owner
